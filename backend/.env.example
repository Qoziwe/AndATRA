FLASK_ENV=development
FLASK_SECRET_KEY=change_this_secret
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/andatra
APP_HOST=0.0.0.0
APP_PORT=5000
FLASK_DEBUG=false
AUTO_SEED_REFERENCE_DATA=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
SOCKETIO_ASYNC_MODE=threading

# LLM Ollama endpoints (3 laptops on local network)
LLM_PRIMARY_URL=http://192.168.0.10:11434
LLM_CLASSIFY_URL=http://192.168.0.11:11434
LLM_SUMMARY_URL=http://192.168.0.12:11434
LLM_VISION_URL=http://192.168.0.12:11434
LLM_PRIMARY_MODEL=llama3
LLM_CLASSIFY_MODEL=mistral
LLM_SUMMARY_MODEL=phi3
LLM_VISION_MODEL=llava
LLM_VISION_ENABLED=true
LLM_MODEL_RESOLUTION_TIMEOUT=2
LLM_PRIMARY_TIMEOUT=45
LLM_CLASSIFY_TIMEOUT=15
LLM_INTAKE_TIMEOUT=10
LLM_VISION_TIMEOUT=10

# Set to false when real Ollama nodes are available
LLM_MOCK_MODE=false

# Reverse geocoding
GEOCODING_ENABLED=true
GEOCODING_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
GEOCODING_USER_AGENT=AndATRA/1.0
GEOCODING_TIMEOUT=6

# Shared secret for Telegram bot authentication
TELEGRAM_BOT_SECRET=shared_secret_token_here
